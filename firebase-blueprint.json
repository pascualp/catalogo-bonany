{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A product in the catalog",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "code": { "type": "string" },
        "name": { "type": "string" },
        "category": { "type": "string" },
        "image": { "type": "string" },
        "format": { "type": "string" },
        "packaging": { "type": "string" },
        "useCase": { "type": "string" },
        "isLocal": { "type": "boolean" },
        "isSeasonal": { "type": "boolean" },
        "landscapeImage": { "type": "string" },
        "price": { "type": "number" },
        "rating": { "type": "number" },
        "description": { "type": "string" },
        "size": { "type": "number" }
      },
      "required": ["id", "name", "category"]
    },
    "AppSettings": {
      "title": "AppSettings",
      "description": "Global application settings like the logo",
      "type": "object",
      "properties": {
        "logo": { "type": "string" }
      }
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "Product",
      "description": "Collection of all products"
    },
    "/settings/global": {
      "schema": "AppSettings",
      "description": "Global settings for the application"
    }
  }
}
