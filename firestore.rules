rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: products
    // Document ID: productId (string)
    // Fields:
    //   - id: string (required)
    //   - code: string (optional)
    //   - name: string (required)
    //   - category: string (required)
    //   - image: string (optional)
    //   - price: number (required)
    //   - rating: number (required)
    //   - description: string (required)
    //   - isLocal: boolean (optional)
    //   - isSeasonal: boolean (optional)
    //   - size: number (optional)
    //
    // Collection: settings
    // Document ID: global
    // Fields:
    //   - logo: string (optional)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "fruitesbonany20@gmail.com" && request.auth.token.email_verified == true);
    }

    function isValidProduct(data) {
      return data.keys().hasAll(['id', 'name', 'category']) &&
             data.id is string &&
             data.name is string && data.name.size() > 0 && data.name.size() < 200 &&
             data.category is string &&
             (!('image' in data) || (data.image is string && data.image.size() < 2000000)) && // 2MB limit for base64
             (!('price' in data) || data.price is number) &&
             (!('rating' in data) || data.rating is number) &&
             (!('description' in data) || data.description is string) &&
             (!('size' in data) || data.size is number);
    }

    function isValidSettings(data) {
      return (!('logo' in data) || (data.logo is string && data.logo.size() < 2000000));
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /products/{productId} {
      allow read: if isAuthenticated();
      allow create, update: if isAdmin() && isValidProduct(request.resource.data);
      allow delete: if isAdmin();
    }

    match /settings/global {
      allow read: if isAuthenticated();
      allow write: if isAdmin() && isValidSettings(request.resource.data);
    }

    match /{path=**} {
      allow read, write: if false;
    }
  }
}
